<Window x:Class="EvidenceStudentu.znamky"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EvidenceStudentu"
        mc:Ignorable="d"
        Title="Přidat hodnocení" Height="320" Width="300">
    <StackPanel Margin="20">
        <Label Content="Označení"/>
        <TextBox x:Name="txtOznaceni" Margin="0,0,0,10"/>
        <Label Content="Váha"/>
        <TextBox x:Name="txtVaha" Margin="0,0,0,10"/>
        <Label Content="Datum"/>
        <DatePicker x:Name="datePicker" Margin="0,0,0,10"/>
        <Button Content="Přidat" Click="BtnPridat_Click"/>
    </StackPanel>
</Window>